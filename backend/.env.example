# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://postgres:password@host:port/railway

# JWT Secret for admin authentication
JWT_SECRET=your-super-secret-jwt-key-change-this

# Admin credentials (change these!)
ADMIN_EMAIL=admin@zapspy.ai
ADMIN_PASSWORD=change-this-password

# Server port
PORT=3000

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-url.com

# Monetizze API (get from Monetizze → Ferramentas → API)
MONETIZZE_CONSUMER_KEY=your-x-consumer-key-from-monetizze

# Z-API WhatsApp Integration (get from z-api.io → Instâncias Web)
ZAPI_INSTANCE_ID=your-instance-id
ZAPI_TOKEN=your-instance-token
ZAPI_CLIENT_TOKEN=your-client-security-token

# Defastra Social Scan (get from rapidapi.com → Phone Deep HLR Lookup by Defastra → Subscribe Basic free plan)
RAPIDAPI_KEY=your-rapidapi-key
