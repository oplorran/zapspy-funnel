{
  "name": "zapspy-backend",
  "version": "1.0.0",
  "description": "Backend API for ZapSpy.ai lead capture and admin panel",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:migrate": "node migrate.js && node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "node migrate.js",
    "lint": "eslint src/ server.js",
    "lint:fix": "eslint src/ server.js --fix",
    "format": "prettier --write \"src/**/*.js\" server.js",
    "format:check": "prettier --check \"src/**/*.js\" server.js",
    "setup:ac": "node src/scripts/setup-activecampaign.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
